{
	"compilerOptions": {
		// "target": "ES2020",
		// "useDefineForClassFields": true,
		// "lib": [
		// 	"ES2024", // steam CEF blocks update to 2022, stuck at Chrome 85
		// 	"DOM",
		// 	"DOM.Iterable"
		// ],
		"module": "ES2022",
		// "types": ["*"],
		"skipLibCheck": true,
		"rootDir": "./src",
		/* Bundler mode */
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"typeRoots": [] // Fixed: Cannot find type definition file for 'eslint__js'
	},
	"include": ["src"],
	// "exclude": [],
	"references": [{ "path": "./tsconfig.node.json" }]
}
